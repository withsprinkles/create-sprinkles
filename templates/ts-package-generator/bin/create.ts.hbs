#!/usr/bin/env node
import { args } from "@bomb.sh/args";
import path from "node:path";

import { produce } from "../src/template.ts";
import { writeTree } from "../src/write.ts";

const { name } = args({ name: { type: "string", required: true } });

const resolvedDir = path.resolve(name);
const creation = await produce({ name });
await writeTree(resolvedDir, creation.files);