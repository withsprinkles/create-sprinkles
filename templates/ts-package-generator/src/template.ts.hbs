import path from "node:path";
import { z } from "zod";

import { renderTemplates } from "./render.ts";

const templatesDir = path.join(import.meta.dirname, "../templates");

const options = {
    name: z.string().describe("Project name"),
};

export { options };

export async function produce(opts: { name: string }) {
    const files = await renderTemplates(path.join(templatesDir, "default"), opts);
    return { files };
}
