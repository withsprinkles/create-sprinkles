import * as s from "@remix-run/data-schema";
import { defineCollection } from "@withsprinkles/content-layer";
import { file, glob } from "@withsprinkles/content-layer/loaders";

let posts = defineCollection({
    loader: glob({
        pattern: "**/[^_]*.{md,mdx}",
        base: "app/content/posts",
    }),
    schema: s.object({
        title: s.string(),
        description: s.string(),
        publishedOn: s.string(),
        isDraft: s.defaulted(s.boolean(), false),
    }),
});

let settings = defineCollection({
    loader: file("app/content/settings.jsonc"),
    schema: s.object({
        id: s.string(),
        label: s.string(),
    }),
});

export let collections = { posts, settings };
