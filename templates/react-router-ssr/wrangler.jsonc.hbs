{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "{{repository}}",
    "main": "./build/server/index.js",
    "compatibility_date": "2025-04-01",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "./build/client",
        "binding": "ASSETS"
    },
    "observability": {
        "enabled": true
    }
}
