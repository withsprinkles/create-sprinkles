{
    "name": "@withsprinkles/workbench",
    "version": "0.1.0",
    "description": "Get started with development by creating projects from templates quickly.",
    "homepage": "https://github.com/withsprinkles/workbench#readme",
    "bugs": {
        "url": "https://github.com/withsprinkles/workbench/issues"
    },
    "license": "MIT",
    "author": "Mark Malstrom <mark@malstrom.me>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/withsprinkles/workbench.git"
    },
    "bin": "./bin/index.ts",
    "files": [
        "bin",
        "dist",
        "templates"
    ],
    "type": "module",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": "./dist/index.mjs",
        "./package.json": "./package.json"
    },
    "scripts": {
        "prepublishOnly": "vp run build"
    },
    "dependencies": {
        "@bomb.sh/args": "^0.3.1",
        "@clack/prompts": "^1.1.0",
        "bingo": "^0.9.2",
        "bingo-fs": "^0.5.6",
        "bingo-handlebars": "^0.1.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^25.3.5",
        "@typescript/native-preview": "latest",
        "bingo-testers": "^0.5.8",
        "bumpp": "^10.4.1",
        "vite-plus": "latest",
        "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "packageManager": "pnpm@10.32.1",
    "pnpm": {
        "overrides": {
            "vite": "npm:@voidzero-dev/vite-plus-core@latest",
            "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
        }
    }
}
