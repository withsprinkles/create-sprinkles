export function cli(): void {
    const { positionals, values } = args({
        allowPositionals: true,
        options: {
            help: {
                short: "h",
                type: "boolean",
                default: false,
                description: "Show help",
            },
            version: {
                short: "v",
                type: "boolean",
                default: false,
                description: "Show version",
            },
        },
