    "import { cloudflare } from "@cloudflare/vite-plugin";
import mdx from "@mdx-js/rollup";
import { unstable_reactRouterRSC as reactRouter } from "@react-router/dev/vite";
import tailwindcss from "@tailwindcss/vite";
