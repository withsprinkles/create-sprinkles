    "home.tsx": [
      "import { getCollection } from "sprinkles:content";

export async function ServerComponent() {
    let posts = await getCollection("posts");

    return (
        <main>
            <h1>Welcome to test-repo</h1>
            <section>
                <h2>Posts</h2>
